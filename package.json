{
  "name": "diangong-dashi",
  "version": "0.1.0",
  "private": true,
  "description": "Web and WeChat mini-program circuit simulation workspace.",
  "scripts": {
    "dev:h5": "taro build --type h5 --watch",
    "build:h5": "taro build --type h5",
    "build:h5:domestic": "TELEMETRY_REGION=domestic TELEMETRY_CHANNEL=h5-cn taro build --type h5",
    "build:h5:overseas": "TELEMETRY_REGION=overseas TELEMETRY_CHANNEL=h5-global taro build --type h5",
    "build:app:domestic": "TELEMETRY_REGION=domestic TELEMETRY_CHANNEL=app-cn taro build --type h5",
    "build:app:overseas": "TELEMETRY_REGION=overseas TELEMETRY_CHANNEL=app-global taro build --type h5",
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "TELEMETRY_REGION=domestic TELEMETRY_CHANNEL=weapp taro build --type weapp",
    "typecheck": "tsc --noEmit",
    "test:physics": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test:compat": "npm run build:h5 && npm run build:weapp",
    "test": "npm run typecheck && npm run test:physics && npm run test:e2e && npm run test:compat"
  },
  "dependencies": {
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "^4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-react": "^7.29.7",
    "@playwright/test": "^1.60.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "4.2.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "babel-preset-taro": "4.2.0",
    "react-refresh": "^0.14.2",
    "sass": "^1.94.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
